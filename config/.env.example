# ============================================================
# X Agent + No.9 共通 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を入力してください
# cp config/.env.example .env
# ============================================================

# ------------------------------------------------------------
# OpenAI API（投稿文生成・感情分類に使用）
# https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------
# Gemini API（オプション）
# https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# X (Twitter) API（デフォルトアカウント用）
# https://developer.twitter.com/en/portal/dashboard
# ------------------------------------------------------------
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
X_BEARER_TOKEN=your_x_bearer_token_here

# ------------------------------------------------------------
# Google Drive（一次情報ソース取得に使用）
# サービスアカウントJSONの内容をそのまま1行で記述 or ファイルパス
# ------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# ------------------------------------------------------------
# Notion（一次情報ソース取得に使用）
# https://www.notion.so/my-integrations
# ------------------------------------------------------------
NOTION_API_TOKEN=your_notion_api_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
NOTION_PAGE_IDS=page_id_1,page_id_2

# ------------------------------------------------------------
# Google Calendar（No.9 商談登録に使用）
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_CALENDAR_ID=primary

# ------------------------------------------------------------
# LINE Notify（No.9 通知に使用）
# https://notify-bot.line.me/my/
# ------------------------------------------------------------
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# ------------------------------------------------------------
# No.9 API サーバー設定（デフォルト: 5003）
# ------------------------------------------------------------
NO9_API_PORT=5003
